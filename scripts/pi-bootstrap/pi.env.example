# Raspberry Pi host identity
PI_HOSTNAME=freshcloud-pi5
ADMIN_USER=ubuntu
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
SSH_DISABLE_PASSWORD_AUTH=true

# Network settings (optional static IP rendering)
PI_INTERFACE=eth0
PI_STATIC_IP_CIDR=192.168.1.50/24
PI_GATEWAY_IP=192.168.1.1
PI_DNS_SERVERS=1.1.1.1,1.0.0.1
PI_NETPLAN_FILE=/etc/netplan/99-freshcloud.yaml
APPLY_NETWORK_CHANGES=false

# Host hardening
ENABLE_UFW=true
ALLOWED_SSH_CIDRS=192.168.1.0/24,100.64.0.0/10
ENABLE_FAIL2BAN=true
ENABLE_UNATTENDED_UPGRADES=true
BACKUP_BASE_DIR=/var/lib/freshcloud/backups

# Tailscale
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=freshcloud-pi5
TAILSCALE_TAGS=tag:freshcloud,tag:admin
TAILSCALE_ENABLE_SSH=true
TAILSCALE_ACCEPT_ROUTES=true
