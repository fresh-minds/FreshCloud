# Backup destination root
BACKUP_DIR=/var/lib/freshcloud/backups

# PostgreSQL source
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# MinIO source
MINIO_SOURCE_ENDPOINT=http://127.0.0.1:9000
MINIO_SOURCE_ACCESS_KEY=minioadmin
MINIO_SOURCE_SECRET_KEY=minioadmin
MINIO_BUCKETS=app-data

# Optional remote MinIO/S3 destination
MINIO_TARGET_ENDPOINT=
MINIO_TARGET_ACCESS_KEY=
MINIO_TARGET_SECRET_KEY=
MINIO_TARGET_PREFIX=freshcloud-pi
