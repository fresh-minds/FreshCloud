[rke2_servers]
cp1 ansible_host=10.10.10.11 node_labels="topology.kubernetes.io/zone=eu-west-nl-a,freshcloud.io/node-group=platform"
cp2 ansible_host=10.10.10.12 node_labels="topology.kubernetes.io/zone=eu-west-nl-a,freshcloud.io/node-group=platform"
cp3 ansible_host=10.10.10.13 node_labels="topology.kubernetes.io/zone=eu-west-nl-a,freshcloud.io/node-group=platform"

[rke2_servers:vars]
ansible_user=ubuntu
ansible_become=true
ansible_ssh_private_key_file=~/.ssh/id_ed25519
