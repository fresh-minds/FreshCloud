# FreshCloud cluster identity
CLUSTER_NAME=freshcloud-mvp
LEASEWEB_REGION=eu-west-nl

# RKE2 install configuration
RKE2_TOKEN=replace-with-a-long-random-token
RKE2_CHANNEL=stable
RKE2_CNI=canal
RKE2_API_HOST=10.10.10.11
RKE2_TLS_SANS=api.freshcloud.example.com,10.10.10.11
RKE2_CLUSTER_CIDR=10.42.0.0/16
RKE2_SERVICE_CIDR=10.43.0.0/16

# SSH and kubeconfig
SSH_USER=ubuntu
SSH_PRIVATE_KEY=~/.ssh/id_ed25519
PRIMARY_NODE_HOST=10.10.10.11
KUBECONFIG_OUTPUT=~/.kube/freshcloud.yaml

# MetalLB and ingress-nginx
METALLB_POOL_NAME=public
METALLB_IP_POOL=203.0.113.70-203.0.113.79
INGRESS_LOADBALANCER_IP=203.0.113.70

# Longhorn storage baseline
LONGHORN_DEFAULT_REPLICA_COUNT=2
LONGHORN_BACKUP_TARGET=s3://freshcloud-longhorn-backups@eu-west/freshcloud
LONGHORN_BACKUP_SECRET=

# Optional node metadata behavior
REMOVE_CONTROL_PLANE_TAINTS=true
INGRESS_NODE=
INGRESS_NODE_TAINT=

# GitOps bootstrap
BOOTSTRAP_ARGOCD=true
ARGOCD_NAMESPACE=argocd
ARGOCD_VERSION=v2.11.7
ARGOCD_ROOT_APP_PATH=
